{:logging
 {:dir {:description "Log directory"
         :type :string
         :default "logs"}

  :file {:description "Log file name"
         :type :string
         :default "app.log"}

  :level {:description "Log level"
          :type :keyword
          :default  :info}}

 :server
 {:port {:description "HTTP server port"
         :type :long
         :default 3000}}

 :spark
 {:app
  {:name {:description "Spark application name"
                :type :string
                :required true}

   :master-url {:description "Spark master URL"
                :type :string
                :required true}}

  :sql
  {:shuffle-partitions
   {:description "Number of shuffle partitions"
    :type :long
    :default 4}}}}